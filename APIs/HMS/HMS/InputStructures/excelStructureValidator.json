{
	"OrgId": 1,
	"InputType": "AgentCreate",
	"fileExtenstion": [
		".xlsx;.xls"
	],
	"excelColumns": [
		{
			"ColumnName": "dob",
			"DestinationDataType": "System.DateTime",
			"DataFormat": "M/d/yyyy h:mm:ss tt",
			"UseRegEx": false,
			"AllowBlank": true,
			"TrimContent": true
		},
		{
			"ColumnName": "aadhaar_number",
			"DestinationDataType": "System.String",
			"DataFormat": "^(?:\\d{12}|\\d{4}\\s\\d{4}\\s\\d{4}|\\d{4}-\\d{4}-\\d{4})$",
			"UseRegEx": true,
			"AllowBlank": false,
			"TrimContent": true
		},
		{
			"ColumnName": "PAN",
			"DestinationDataType": "System.String",
			"DataFormat": "^[A-Z]{5}[0-9]{4}[A-Z]$",
			"UseRegEx": true,
			"AllowBlank": true,
			"TrimContent": true
		}
	]
}