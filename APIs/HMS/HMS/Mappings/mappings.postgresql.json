{
  "ConnectionStringKey": "HMSContext",
  "Entities": {
    "Agent": {
      "Insert": {
        "Function": "hms.insert_agent",
        "Script": "SELECT * FROM hms.insert_agent (@AgentCode, @AgentTypeCode, @AgentSubTypeCode, @AgentName, @BusinessName, @FirstName, @MiddleName, @LastName, @Prefix, @Suffix, @Gender, @Dob, @Nationality, @MaritalStatusCode, @PreferredLanguage, @ChannelCode, @SubChannelCode, @DesignationCode, @AgentLevel, @LocationCode, @StaffCode, @SupervisorCode, @ContractedDate, @AgentStatusCode, @StatusDate, @IsLicensed, @PanNumber, @AadhaarNumber, @IrdaLicenseNumber, @GstNumber, @Email, @MobileNo, @CreatedBy)"
      },
      "Search": {
        "Function": "hms.search_agents",
        "Script": "SELECT * FROM hms.search_agents (@p_agent_name, @p_email, @p_mobileno, @p_pan_number, @p_aadhaar_number, @p_irda_license_number, @p_gst_number, @p_page_number, @p_page_size, @p_sort_column, @p_sort_direction)"
      },
      "Search1": {
        "Function": "hms.get_agentSearch",
        "Script": "SELECT * from hms.get_agentSearch (@p_searchcondition,@p_zone, @p_page_number, @p_page_size, @p_sort_column, @p_sort_direction)"
      },
      "SaveAgentlicense": {
        "Function": "hms.insert_agent_license",
        "Script": "SELECT * from hms.insert_agent_license (@p_agent_id, @p_license_no, @p_license_type_code, @p_effective_from_date, @p_created_by,@p_effective_to_date,@p_license_status,@p_modified_by,@p_rowversion)"
      },
      "get_agent_hierarchy_json": {
        "Function": "hms.get_agent_supervisors",
        "Script": "SELECT hms.get_agent_supervisors(@p_agent_id)"
      }
    }
  }
}
